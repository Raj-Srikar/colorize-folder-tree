{
  "name": "colorize-folder-tree",
  "displayName": "Colorize Folder Tree",
  "description": "Rainbow nesting borders for folders in the VS Code Explorer — like bracket pair colorization, but for your file tree.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "colorize-folder-tree.toggle",
        "title": "Colorize Folder Tree: Toggle Rainbow Borders"
      },
      {
        "command": "colorize-folder-tree.enable",
        "title": "Colorize Folder Tree: Enable Rainbow Borders"
      },
      {
        "command": "colorize-folder-tree.disable",
        "title": "Colorize Folder Tree: Disable Rainbow Borders"
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "dependencies": {
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "eslint": "^9.39.2",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
