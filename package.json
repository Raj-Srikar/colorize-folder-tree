{
  "name": "colorize-folder-tree",
  "displayName": "Colorize Folder Tree",
  "publisher": "RajSrikar",
  "repository": {
    "type": "git",
    "url": "https://github.com/Raj-Srikar/colorize-folder-tree"
  },
  "license": "MIT",
  "description": "Rainbow nesting borders for folders in the VS Code Explorer — like bracket pair colorization, but for your file tree.",
  "version": "0.0.2",
  "engines": {
    "vscode": "^1.113.0"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "colorize-folder-tree.enable",
        "title": "Colorize Folder Tree: Enable Rainbow Tree On Hover [DEFAULT]"
      },
      {
        "command": "colorize-folder-tree.disable",
        "title": "Colorize Folder Tree: Disable Rainbow Tree"
      }
      ,
      {
        "command": "colorize-folder-tree.enableAlways",
        "title": "Colorize Folder Tree: Enable Rainbow Tree Always"
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "dependencies": {
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "eslint": "^9.39.2",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
